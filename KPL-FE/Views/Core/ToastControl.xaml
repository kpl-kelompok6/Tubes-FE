<UserControl x:Class="KPL_FE.Views.ToastControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             x:Name="ToastRoot"
             Height="Auto"
             Width="360">
    <Border x:Name="ToastBorder"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0"
            CornerRadius="8"
            Margin="0,0,0,8"
            UseLayoutRounding="True"
            Effect="{DynamicResource SystemControlDropShadowEffect}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Rectangle x:Name="AccentBar"
                       Grid.Column="0"
                       Fill="{Binding ElementName=ToastRoot, Path=AccentColor}"
                       Width="6"
                       RadiusX="3"
                       RadiusY="3"
                       HorizontalAlignment="Left"/>

            <TextBlock x:Name="IconText"
                       Grid.Column="1"
                       FontSize="18"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="12,12,0,12"
                       FontFamily="Segoe MDL2 Assets"
                       Text="{Binding ElementName=ToastRoot, Path=ToastIcon}"/>

            <TextBlock x:Name="MessageText"
                       Grid.Column="2"
                       Text="{Binding ElementName=ToastRoot, Path=Message}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Margin="10,12,0,12"
                       FontSize="14"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

            <Button x:Name="CloseButton"
                    Grid.Column="3"
                    Content="&#xE894;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="12"
                    Width="28"
                    Height="28"
                    Margin="0,8,8,0"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                    Cursor="Hand"
                    Click="CloseButton_Click"/>
        </Grid>
    </Border>
</UserControl>

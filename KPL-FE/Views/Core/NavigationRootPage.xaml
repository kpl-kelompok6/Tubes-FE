<UserControl
    x:Class="KPL_FE.Views.NavigationRootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <DockPanel Background="{DynamicResource NavigationViewExpandedPaneBackground}">
            <ui:ListView
                x:Name="PagesList"
                Margin="0,12,0,0"
                DisplayMemberPath="Title"
                SelectedValuePath="PageType"
                SelectionChanged="PagesList_SelectionChanged" />
        </DockPanel>

        <ui:Frame x:Name="RootFrame" Grid.Column="1" Navigated="RootFrame_Navigated"/>
    </Grid>
</UserControl>

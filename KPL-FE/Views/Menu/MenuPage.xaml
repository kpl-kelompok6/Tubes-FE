<Page x:Class="KPL_FE.Views.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Menu">

    <Page.Resources>
        <Style x:Key="FilterRadio" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Width" Value="280" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
        </Style>

        <Style x:Key="StateCard" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseMediumBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Menu" FontSize="24" FontWeight="SemiBold" />

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="FilterAll" GroupName="CategoryFilter" Content="Semua"
                             Style="{StaticResource FilterRadio}" IsChecked="True"
                             Checked="Filter_Checked" />
                <RadioButton x:Name="FilterMakanan" GroupName="CategoryFilter" Content="Makanan"
                             Style="{StaticResource FilterRadio}"
                             Checked="Filter_Checked" />
                <RadioButton x:Name="FilterMinuman" GroupName="CategoryFilter" Content="Minuman"
                             Style="{StaticResource FilterRadio}"
                             Checked="Filter_Checked" />
            </StackPanel>
            <Button Grid.Column="1" x:Name="AddButton" Click="AddButton_Click" MinWidth="100">
                + Tambah
            </Button>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="MenuItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <Border Margin="0,4,0,0" Padding="4,2" CornerRadius="4"
                                            Background="{DynamicResource SystemControlHighlightAccentBrush}">
                                        <TextBlock Text="{Binding Category}" FontSize="11" Foreground="White" />
                                    </Border>
                                    <TextBlock Text="{Binding PriceFormatted}" FontSize="20"
                                               FontWeight="Bold" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding Description}" Opacity="0.7"
                                               TextWrapping="Wrap" MaxHeight="40" Margin="0,4,0,0" />
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Click="EditButton_Click" MinWidth="72" Margin="0,0,8,0"
                                                Tag="{Binding}">Edit</Button>
                                        <Button Click="DeleteButton_Click" MinWidth="72"
                                                Tag="{Binding}">Hapus</Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border x:Name="LoadingOverlay" Style="{StaticResource StateCard}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center">
                    <ui:ProgressRing Width="52" Height="52" IsActive="True" HorizontalAlignment="Center" />
                    <TextBlock Text="Memuat data menu..." Margin="0,12,0,0" HorizontalAlignment="Center" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border x:Name="ErrorStatePanel" Style="{StaticResource StateCard}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" MaxWidth="420">
                <StackPanel>
                    <TextBlock Text="Gagal memuat menu" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock x:Name="ErrorMessageText" Text="Server tidak merespons." Margin="0,8,0,0" Opacity="0.75" TextAlignment="Center" TextWrapping="Wrap" />
                    <Button Content="Coba Lagi" Margin="0,16,0,0" HorizontalAlignment="Center" Click="RetryButton_Click" />
                </StackPanel>
            </Border>

            <Border x:Name="EmptyStatePanel" Style="{StaticResource StateCard}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" MaxWidth="420">
                <StackPanel>
                    <TextBlock x:Name="EmptyStateTitleText" Text="Data Kosong" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock x:Name="EmptyStateMessageText" Text="Belum ada menu tersedia." Margin="0,8,0,0" Opacity="0.75" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

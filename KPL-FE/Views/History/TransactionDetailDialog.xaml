<Window x:Class="KPL_FE.Views.TransactionDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Detail Transaksi"
        Width="520" Height="520"
        MinWidth="400" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        ShowInTaskbar="False"
        ui:WindowHelper.UseModernWindowStyle="True">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="TxCodeText" FontSize="22" FontWeight="SemiBold" />
            <TextBlock x:Name="TxDateText" FontSize="12" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border CornerRadius="8" Padding="16"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Pelanggan" FontSize="12" Opacity="0.6" VerticalAlignment="Center" />
                        <TextBlock x:Name="TxCustomerText" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Margin="16,0,0,0" />

                        <TextBlock Grid.Row="1" Text="Meja" FontSize="12" Opacity="0.6" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <TextBlock x:Name="TxTableText" Grid.Row="1" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Margin="16,8,0,0" />

                        <TextBlock Grid.Row="2" Text="Pembayaran" FontSize="12" Opacity="0.6" VerticalAlignment="Center" Margin="0,8,0,0" />
                        <TextBlock x:Name="TxPaymentText" Grid.Row="2" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Margin="16,8,0,0" />

                        <Border Grid.Row="3" Grid.ColumnSpan="2" Margin="0,12,0,0" Height="1"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" />
                    </Grid>
                </Border>

                <TextBlock Text="Item Pesanan" FontSize="15" FontWeight="SemiBold" Margin="0,16,0,8" />

                <ItemsControl x:Name="ItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,8" Margin="0,0,0,4" CornerRadius="6"
                                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding MenuName}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding UnitPriceFormatted}" FontSize="11" Opacity="0.5" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SubtotalFormatted}" FontSize="13" FontWeight="Bold"
                                                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding Quantity, StringFormat=x{0}}" FontSize="11" Opacity="0.5"
                                                   HorizontalAlignment="Right" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="EmptyItemsText" Text="Tidak ada item." FontSize="13" Opacity="0.5" HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed" />

                <Border CornerRadius="8" Padding="16" Margin="0,12,0,0"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Total" FontSize="12" Opacity="0.6" />
                            <TextBlock x:Name="TxTotalText" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource SystemControlHighlightAccentBrush}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                            <TextBlock Text="Dibayar" FontSize="11" Opacity="0.5" HorizontalAlignment="Right" />
                            <TextBlock x:Name="TxPaidText" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,2,0,0" />
                            <TextBlock Text="Kembalian" FontSize="11" Opacity="0.5" HorizontalAlignment="Right" Margin="0,6,0,0" />
                            <TextBlock x:Name="TxChangeText" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Tutup" HorizontalAlignment="Right" MinWidth="100" Margin="0,16,0,0"
                Click="CloseButton_Click" />
    </Grid>
</Window>

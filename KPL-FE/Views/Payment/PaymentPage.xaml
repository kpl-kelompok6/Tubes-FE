<Page x:Class="KPL_FE.Views.PaymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Payment">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Pembayaran" FontSize="24" FontWeight="SemiBold" />

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="PaymentsListBox" SelectionChanged="PaymentsListBox_SelectionChanged"
                         Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Padding="12" BorderThickness="1"
                                    BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center" MinWidth="80">
                                        <TextBlock Text="{Binding DateFormatted}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding TimeFormatted}" FontSize="11" Opacity="0.5" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TransactionCode, StringFormat=#{0}}" FontSize="13" FontWeight="Bold" />
                                        <TextBlock Text="{Binding PaymentMethodDisplay}" FontSize="11" Opacity="0.6" Margin="0,2,0,0" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding TotalAmountFormatted}" FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <Border x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="12" Padding="20" BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}">
                <StackPanel HorizontalAlignment="Center">
                    <ui:ProgressRing Width="48" Height="48" IsActive="True" HorizontalAlignment="Center" />
                    <TextBlock Text="Memuat pembayaran..." Margin="0,12,0,0" HorizontalAlignment="Center" FontWeight="SemiBold" />
                </StackPanel>
            </Border>

            <Border x:Name="ErrorPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="12" Padding="20" BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}" MaxWidth="360">
                <StackPanel>
                    <TextBlock Text="Gagal memuat pembayaran" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock x:Name="ErrorText" Text="Server tidak merespons." Margin="0,8,0,0" Opacity="0.75" TextWrapping="Wrap" TextAlignment="Center" />
                    <Button Content="Coba Lagi" Margin="0,16,0,0" HorizontalAlignment="Center" Click="RetryButton_Click" />
                </StackPanel>
            </Border>

            <Border x:Name="EmptyPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="12" Padding="20" BorderThickness="1"
                    BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}" MaxWidth="360">
                <StackPanel>
                    <TextBlock Text="Data Kosong" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" />
                    <TextBlock x:Name="EmptyText" Text="Belum ada pembayaran." Margin="0,8,0,0" Opacity="0.75" TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
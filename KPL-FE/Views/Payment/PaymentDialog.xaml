<Window x:Class="KPL_FE.Views.Payment.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Pembayaran" Height="400" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Proses Pembayaran" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,24"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Total Tagihan" Foreground="Gray" Margin="0,0,0,4"/>
            <TextBlock x:Name="TotalTagihanText" Text="Rp 0" FontSize="28" FontWeight="Bold" Margin="0,0,0,16"/>

            <TextBlock Text="Jumlah Uang (Rp)" Foreground="Gray" Margin="0,0,0,4"/>
            <TextBox x:Name="PaidAmountTextBox" FontSize="18" TextChanged="PaidAmountTextBox_TextChanged" Margin="0,0,0,16" />

            <TextBlock Text="Kembalian" Foreground="Gray" Margin="0,0,0,4"/>
            <TextBlock x:Name="ChangeAmountText" Text="Rp 0" FontSize="18" FontWeight="SemiBold" Foreground="Green"/>
            
            <TextBlock x:Name="ErrorText" Foreground="Red" Margin="0,16,0,0" Visibility="Collapsed" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="Batal" Click="CancelButton_Click" HorizontalAlignment="Stretch" />
            <Button x:Name="SubmitButton" Grid.Column="2" Content="Bayar Sekarang" Click="SubmitButton_Click" 
                    HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" />
        </Grid>
        </Grid>
    </Border>
</Window>

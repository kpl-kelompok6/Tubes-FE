<Page x:Class="KPL_FE.Views.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Menu">

    <Page.Resources>
        <Style x:Key="FilterRadio" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Width" Value="280" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" />
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Menu" FontSize="24" FontWeight="SemiBold" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="24,0,0,0">
                <RadioButton x:Name="FilterAll" GroupName="CategoryFilter" Content="Semua"
                             Style="{StaticResource FilterRadio}" IsChecked="True"
                             Checked="Filter_Checked" />
                <RadioButton x:Name="FilterMakanan" GroupName="CategoryFilter" Content="Makanan"
                             Style="{StaticResource FilterRadio}"
                             Checked="Filter_Checked" />
                <RadioButton x:Name="FilterMinuman" GroupName="CategoryFilter" Content="Minuman"
                             Style="{StaticResource FilterRadio}"
                             Checked="Filter_Checked" />
            </StackPanel>
            <Button Grid.Column="2" x:Name="AddButton" Click="AddButton_Click" MinWidth="100">
                + Tambah
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="2" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MenuItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <Border Margin="0,4,0,0" Padding="4,2" CornerRadius="4"
                                        Background="{DynamicResource SystemAccentColor}">
                                    <TextBlock Text="{Binding Category}" FontSize="11" Foreground="White" />
                                </Border>
                                <TextBlock Text="{Binding PriceFormatted}" FontSize="20"
                                           FontWeight="Bold" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding Description}" Opacity="0.7"
                                           TextWrapping="Wrap" MaxHeight="40" Margin="0,4,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Click="EditButton_Click" MinWidth="72" Margin="0,0,8,0"
                                            Tag="{Binding}">Edit</Button>
                                    <Button Click="DeleteButton_Click" MinWidth="72"
                                            Tag="{Binding}">Hapus</Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>

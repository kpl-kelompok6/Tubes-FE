<Window x:Class="KPL_FE.Views.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        Title="Login - KPL POS"
        Width="400" Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        ui:WindowHelper.UseModernWindowStyle="True">

    <Window.Resources>
        <!-- Segmented Control Radio Button Style -->
        <Style x:Key="ModeRadio" TargetType="RadioButton">
            <Setter Property="Padding" Value="0,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24" VerticalAlignment="Center">

                <TextBlock Text="KPL POS" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="Point of Sale System" FontSize="13" Opacity="0.6"
                           HorizontalAlignment="Center" Margin="0,0,0,24" />

                <!-- Segmented Control Wrapper -->
                <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                        CornerRadius="8" Padding="4" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <RadioButton x:Name="ModeLogin" GroupName="AuthMode" Content="Login"
                                     IsChecked="True" Checked="ModeSwitch_Checked"
                                     Style="{StaticResource ModeRadio}" Grid.Column="0" />
                        
                        <RadioButton x:Name="ModeRegister" GroupName="AuthMode" Content="Register"
                                     Checked="ModeSwitch_Checked"
                                     Style="{StaticResource ModeRadio}" Grid.Column="1" />
                    </Grid>
                </Border>

                <!-- Login Mode -->
                <StackPanel x:Name="LoginPanel">
                    <TextBox x:Name="LoginUsernameBox" ui:ControlHelper.Header="Username"
                             Margin="0,0,0,12" MaxLength="50" />
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Password" FontSize="13" Margin="0,0,0,4"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <PasswordBox x:Name="LoginPasswordBox" MaxLength="100" />
                                <TextBox x:Name="LoginPasswordTextBox" MaxLength="100" Visibility="Collapsed" />
                            </Grid>
                            <ToggleButton x:Name="LoginPasswordToggle" Grid.Column="1" Width="30" Height="30" Margin="4,0,0,0"
                                          Content="👁" FontSize="14" ToolTip="Tampilkan password" />
                        </Grid>
                    </StackPanel>

                    <Button x:Name="LoginButton" Content="Login"
                            Style="{DynamicResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch" Height="40" FontSize="14"
                            IsEnabled="False" Click="LoginButton_Click" />
                </StackPanel>

                <!-- Register Mode -->
                <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">
                    <TextBox x:Name="RegUsernameBox" ui:ControlHelper.Header="Username"
                             Margin="0,0,0,12" MaxLength="50" />
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Password" FontSize="13" Margin="0,0,0,4"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <PasswordBox x:Name="RegPasswordBox" MaxLength="100" />
                                <TextBox x:Name="RegPasswordTextBox" MaxLength="100" Visibility="Collapsed" />
                            </Grid>
                            <ToggleButton x:Name="RegPasswordToggle" Grid.Column="1" Width="30" Height="30" Margin="4,0,0,0"
                                          Content="👁" FontSize="14" ToolTip="Tampilkan password" />
                        </Grid>
                    </StackPanel>
                    <TextBox x:Name="RegDisplayNameBox" ui:ControlHelper.Header="Display Name"
                             Margin="0,0,0,12" MaxLength="100" />
                    <ComboBox x:Name="RegRoleCombo" ui:ControlHelper.Header="Role" Margin="0,0,0,20"
                              HorizontalAlignment="Stretch" SelectedIndex="0">
                        <ComboBoxItem>Kasir</ComboBoxItem>
                        <ComboBoxItem>Admin</ComboBoxItem>
                    </ComboBox>

                    <Button x:Name="RegisterButton" Content="Register"
                            Style="{DynamicResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch" Height="40" FontSize="14"
                            IsEnabled="False" Click="RegisterButton_Click" />
                </StackPanel>

                <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap"
                           Margin="0,12,0,0" TextAlignment="Center" Height="36" />

                <StackPanel x:Name="AuthLoadingPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0" Visibility="Collapsed">
                    <ui:ProgressRing x:Name="AuthLoadingRing" Width="24" Height="24" IsActive="False" />
                    <TextBlock Text="Memproses..." Margin="8,0,0,0" VerticalAlignment="Center" Opacity="0.75" />
                </StackPanel>

                <Button x:Name="CancelButton" Content="Cancel"
                        HorizontalAlignment="Center" Margin="0,8,0,0"
                        Click="CancelButton_Click" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

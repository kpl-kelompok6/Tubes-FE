<Page x:Class="KPL_FE.Views.TransactionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Transaction">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Transaksi Aktif" FontSize="22" FontWeight="SemiBold" />

            <Button Grid.Row="1" x:Name="NewTransactionButton" Click="NewTransactionButton_Click"
                    Content="+ Transaksi Baru" HorizontalAlignment="Stretch" Margin="0,12,0,0" Height="38"
                    Style="{DynamicResource AccentButtonStyle}" />

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="TransactionsListBox" SelectionChanged="TransactionsListBox_SelectionChanged"
                             Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12" BorderThickness="1"
                                        BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DisplayCode}" FontWeight="Bold" FontSize="13" 
                                                       TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                            <Border Grid.Column="1" Padding="6,2" CornerRadius="4" Background="{DynamicResource SystemControlHighlightAccentBrush}">
                                                <TextBlock Text="{Binding Status}" FontSize="10" Foreground="White" FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="1" Text="{Binding SummaryText}" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0" />

                                        <Grid Grid.Row="2" Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TotalAmountFormatted}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding CreatedAt, StringFormat={}{0:HH:mm}}" Opacity="0.6" VerticalAlignment="Center" FontSize="11" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <Border x:Name="TransactionsLoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="12" Padding="20" BorderThickness="1"
                        BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}">
                    <StackPanel HorizontalAlignment="Center">
                        <ui:ProgressRing Width="48" Height="48" IsActive="True" HorizontalAlignment="Center" />
                        <TextBlock Text="Memuat transaksi..." Margin="0,12,0,0" HorizontalAlignment="Center" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border x:Name="TransactionsErrorPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="12" Padding="20" BorderThickness="1"
                        BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}" MaxWidth="360">
                    <StackPanel>
                        <TextBlock Text="Gagal memuat transaksi" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" />
                        <TextBlock x:Name="TransactionsErrorText" Text="Server tidak merespons." Margin="0,8,0,0" Opacity="0.75" TextWrapping="Wrap" TextAlignment="Center" />
                        <Button Content="Coba Lagi" Margin="0,16,0,0" HorizontalAlignment="Center" Click="RetryTransactionsButton_Click" />
                    </StackPanel>
                </Border>

                <Border x:Name="TransactionsEmptyPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="12" Padding="20" BorderThickness="1"
                        BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}" MaxWidth="360">
                    <StackPanel>
                        <TextBlock Text="Data Kosong" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" />
                        <TextBlock Text="Belum ada transaksi aktif." Margin="0,8,0,0" Opacity="0.75" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Column="2">
            <Grid x:Name="EmptyStatePanel" Visibility="Visible" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Belum ada transaksi terpilih" FontSize="20" FontWeight="SemiBold" Opacity="0.5" HorizontalAlignment="Center" />
                    <TextBlock Text="Pilih transaksi dari daftar kiri atau buat transaksi baru untuk mulai memasukkan pesanan." FontSize="14" Opacity="0.4" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap" MaxWidth="400" />
                </StackPanel>
            </Grid>

            <Grid x:Name="MenuBrowserPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Pilih Menu" FontSize="22" FontWeight="SemiBold" />

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <RadioButton x:Name="FilterAll" Content="Semua" GroupName="MenuFilter" IsChecked="True"
                                 Checked="MenuFilter_Checked" Style="{StaticResource {x:Type ToggleButton}}"
                                 Margin="0,0,8,0" Padding="12,6" />
                    <RadioButton x:Name="FilterMakanan" Content="Makanan" GroupName="MenuFilter"
                                 Checked="MenuFilter_Checked" Style="{StaticResource {x:Type ToggleButton}}"
                                 Margin="0,0,8,0" Padding="12,6" />
                    <RadioButton x:Name="FilterMinuman" Content="Minuman" GroupName="MenuFilter"
                                 Checked="MenuFilter_Checked" Style="{StaticResource {x:Type ToggleButton}}"
                                 Padding="12,6" />
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="MenuItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12" Margin="0,0,12,12" Width="185" Height="220" BorderThickness="1"
                                            BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="90" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Image -->
                                            <Border Grid.Row="0" CornerRadius="6" ClipToBounds="True" Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                                <Grid>
                                                    <TextBlock Text="🍽️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3" />
                                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Grid>
                                            </Border>

                                            <!-- Title -->
                                            <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,0" TextTrimming="CharacterEllipsis" />

                                            <!-- Category -->
                                            <TextBlock Grid.Row="2" Text="{Binding Category}" FontSize="10" Opacity="0.5" Margin="0,2,0,0" />

                                            <!-- Bottom: Price & Add Button -->
                                            <Grid Grid.Row="3" Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding PriceFormatted}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                                                <Button Grid.Column="1" Content="+ Tambah" Tag="{Binding}" Click="AddMenuItemButton_Click" Style="{DynamicResource AccentButtonStyle}" Padding="8,4" FontSize="11" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border x:Name="MenuLoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="12" Padding="20" BorderThickness="1"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}">
                        <StackPanel HorizontalAlignment="Center">
                            <ui:ProgressRing Width="48" Height="48" IsActive="True" HorizontalAlignment="Center" />
                            <TextBlock Text="Memuat menu..." Margin="0,12,0,0" HorizontalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="MenuErrorPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="12" Padding="20" BorderThickness="1"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}" MaxWidth="360">
                        <StackPanel>
                            <TextBlock Text="Gagal memuat menu" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" />
                            <TextBlock x:Name="MenuErrorText" Text="Server tidak merespons." Margin="0,8,0,0" Opacity="0.75" TextWrapping="Wrap" TextAlignment="Center" />
                            <Button Content="Coba Lagi" Margin="0,16,0,0" HorizontalAlignment="Center" Click="RetryMenusButton_Click" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="MenuEmptyPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="12" Padding="20" BorderThickness="1"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}" MaxWidth="360">
                        <StackPanel>
                            <TextBlock x:Name="MenuEmptyTitleText" Text="Data Kosong" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" />
                            <TextBlock x:Name="MenuEmptyMessageText" Text="Belum ada menu untuk ditampilkan." Margin="0,8,0,0" Opacity="0.75" TextWrapping="Wrap" TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.Column="4">
            <Grid x:Name="CartPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock x:Name="SelectedTxCodeText" Text="Detail Transaksi #TX..." FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="SelectedTxCustomerText" Text="Pelanggan: -" FontSize="13" Opacity="0.7" Margin="0,4,0,0" />
                </StackPanel>

                <Border x:Name="OperationErrorOverlay" Grid.Row="1" Visibility="Collapsed"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="8" Padding="12" BorderThickness="1"
                        BorderBrush="#E81123" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Operasi Gagal" FontSize="13" FontWeight="Bold" Foreground="#E81123" />
                            <TextBlock x:Name="OperationErrorText" Text="Server tidak merespons." FontSize="11" Margin="0,4,0,0" Opacity="0.8" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Button Content="Coba Lagi" Padding="8,4" FontSize="11" Style="{DynamicResource AccentButtonStyle}" Click="RetryOperationButton_Click" />
                            <Button Content="✕" Width="24" Height="24" Padding="0" FontSize="10" Margin="6,0,0,0" Click="DismissOperationErrorButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Margin="0,12,0,0" CornerRadius="8"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Padding="4">
                    <Grid>
                        <TextBlock x:Name="EmptyCartText" Text="Keranjang kosong — pilih menu untuk menambah item"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0.4" FontSize="13" TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="16" />

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="CartItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" Margin="0,0,0,1"
                                                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding MenuName}" FontSize="13" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding SubtotalFormatted}"
                                                               FontSize="13" FontWeight="Bold"
                                                               Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                                                </Grid>

                                                <Grid Grid.Row="1" Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding UnitPriceFormatted}" FontSize="11" Opacity="0.5"
                                                               VerticalAlignment="Center" />

                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="−" Width="28" Height="28" Padding="0" FontSize="14"
                                                                Tag="{Binding}" Click="DecreaseQtyButton_Click" />
                                                        <TextBlock Text="{Binding Quantity}" FontSize="13" FontWeight="SemiBold"
                                                                   Margin="8,0" VerticalAlignment="Center" MinWidth="20" TextAlignment="Center" />
                                                        <Button Content="+" Width="28" Height="28" Padding="0" FontSize="14"
                                                                Tag="{Binding}" Click="IncreaseQtyButton_Click" />
                                                        <Button Content="✕" Width="28" Height="28" Padding="0" FontSize="11"
                                                                Tag="{Binding}" Click="RemoveItemButton_Click" Margin="6,0,0,0"
                                                                Foreground="Red" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="3" Margin="0,12,0,0">
                    <TextBlock Text="Total Pembayaran" FontSize="12" Opacity="0.7" />
                    <TextBlock x:Name="SelectedTxTotalText" Text="Rp 0" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlHighlightAccentBrush}" />
                    
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="CancelTransactionButton" Content="Batalkan" Height="42" HorizontalAlignment="Stretch"
                                Foreground="White" Background="{DynamicResource SystemControlErrorTextForegroundBrush}"
                                FontSize="14" IsEnabled="False" Click="CancelTransactionButton_Click" />
                        <Button x:Name="PayButton" Grid.Column="2" Content="Bayar Sekarang" Height="42" HorizontalAlignment="Stretch"
                                Style="{DynamicResource AccentButtonStyle}" FontSize="14" IsEnabled="False" Click="PayButton_Click" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Border x:Name="OperationLoadingOverlay" Visibility="Collapsed"
                    Background="#33000000" CornerRadius="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Grid>
                    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            CornerRadius="8" Padding="16" BorderThickness="1"
                            BorderBrush="{DynamicResource SystemControlBackgroundBaseMediumBrush}">
                        <StackPanel Orientation="Horizontal">
                            <ui:ProgressRing x:Name="OperationLoadingRing" Width="20" Height="20" IsActive="False" VerticalAlignment="Center" />
                            <TextBlock Text="Memproses..." Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>

<Page x:Class="KPL_FE.Views.ThemeResourcesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Theme Resources">

    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Theme Resources" FontSize="24" Margin="0,0,0,8" />
            <TextBlock Text="Placeholder page. Add theme resource demos here." Opacity="0.8" />

            <Border Margin="0,16,0,0"
                    Padding="16"
                    Background="{DynamicResource AppContentBackgroundBrush}">
                <StackPanel>
                    <TextBlock Text="AppContentBackgroundBrush sample" />
                    <Rectangle Height="24" Margin="0,8,0,0" Fill="{DynamicResource CustomThemeBrush}" />
                    <TextBlock Text="CustomThemeBrush sample" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
